{
  "fields": [
    {
      "path": "candidate_name",
      "from": "full_name",
      "type": "string"
    },
    {
      "path": "primary_email",
      "from": "emails[0]",
      "type": "string"
    },
    {
      "path": "phone",
      "from": "phones[0]",
      "type": "string",
      "normalize": "E164"
    },
    {
      "path": "skills",
      "from": "skills[].name",
      "type": "string[]"
    }
  ],
  "include_confidence": false,
  "include_provenance": false,
  "on_missing": "omit"
}